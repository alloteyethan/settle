# PostgreSQL connection (required for API)
DATABASE_URL=postgresql://user:password@localhost:5432/settle

# API server port (local dev)
PORT=8080

# Frontend dev server
VITE_PORT=5173
BASE_PATH=/

# Public URL for payment callbacks and email links (production)
# APP_URL=https://your-app.vercel.app

# Paystack (optional — required for real payments)
# PAYSTACK_SECRET_KEY=sk_test_...

# Email notifications via Resend (optional)
# RESEND_API_KEY=re_...
